      {
        "blockType": "split-content",
        "tag": "Your Vehicle's Digital Fingerprint",
        "heading": "What is a **Peugeot VIN Decoder**?",
        "headingLevel": "h2",
        "description": {
          "root": {
            "type": "root",
            "direction": "ltr",
